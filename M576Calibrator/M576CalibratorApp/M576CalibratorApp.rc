    LTEXT           "MCS (Z4671 bundle):",-1,7,34,120,8
    CONTROL         "*_mcs1.bin (trans1)",IDC_BURN_CHECK_MCS1,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,46,135,9
    CONTROL         "*_mcs2.bin (trans2)",IDC_BURN_CHECK_MCS2,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,60,135,9
    LTEXT           "1x64 #1 (trans3), per switch 2K:",-1,7,76,160,8
