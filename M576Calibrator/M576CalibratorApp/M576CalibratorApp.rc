IDD_M576_BURN_SELECT DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Burn: select per-trans .bin"
FONT 10, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "Output base (per-trans files):",-1,7,7,286,9
